---
interface Props {
  sources: Array<{ title: string; url: string; accessDate?: string }>;
  notes?: string;
}

const { sources, notes } = Astro.props;
---

<section aria-labelledby="sources-heading" class="bg-base-200 rounded-xl p-6 mt-8">
  <h2 id="sources-heading" class="text-xl font-bold mb-4">Sources & References</h2>
  <ol class="list-decimal list-inside space-y-2">
    {sources.map((source) => (
      <li>
        <a
          href={source.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary hover:underline"
        >
          {source.title}
        </a>
        {source.accessDate && (
          <span class="text-sm text-base-content/70 ml-1">
            (accessed {source.accessDate})
          </span>
        )}
      </li>
    ))}
  </ol>
  {notes && (
    <div class="mt-4 pt-4 border-t border-base-300 text-sm text-base-content/70">
      <Fragment set:html={notes} />
    </div>
  )}
</section>
