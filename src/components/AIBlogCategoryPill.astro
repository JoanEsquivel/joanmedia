---
import { AI_BLOG_CATEGORIES, type AIBlogCategory } from "../lib/aiBlogCategories";

interface Props {
  category: AIBlogCategory;
  isActive?: boolean;
}

const { category, isActive = false } = Astro.props;
const cat = AI_BLOG_CATEGORIES[category];
---

<span
  class:list={[
    "badge",
    isActive ? "badge-primary" : "badge-outline",
  ]}
>
  <span aria-hidden="true">{cat.icon}</span>&nbsp;{cat.label}
</span>
