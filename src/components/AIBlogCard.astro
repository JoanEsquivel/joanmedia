---
import { Image } from "astro:assets";
import { AI_BLOG_CATEGORIES, type AIBlogCategory } from "../lib/aiBlogCategories";

interface Props {
  title: string;
  img?: string;
  desc: string;
  url: string;
  badge?: string;
  tags?: string[];
  pubDate?: string;
  category: AIBlogCategory;
  series?: string;
  seriesOrder?: number;
  seriesTotal?: number;
}

const { title, img, desc, url, badge, tags = [], pubDate, category, series, seriesOrder, seriesTotal } = Astro.props;

const month = pubDate ? new Date(pubDate).toISOString().slice(0, 7) : "";
const formattedDate = pubDate
  ? new Date(pubDate).toLocaleDateString("en-US", {
      month: "long",
      day: "2-digit",
      year: "numeric",
    })
  : "";

const cat = AI_BLOG_CATEGORIES[category];
---

<article
  class="ai-blog-card card bg-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group overflow-hidden"
  data-title={title?.toLowerCase()}
  data-description={desc?.toLowerCase()}
  data-tags={tags.join(",").toLowerCase()}
  data-month={month}
  data-date={pubDate}
  data-category={category}
  data-series={series || ""}
  data-series-order={seriesOrder || ""}
>
  <a href={url} class="block focus-visible:outline-offset-4">
    {img && (
      <figure class="h-48 overflow-hidden relative">
        <Image
          src={img}
          alt=""
          loading="lazy"
          decoding="async"
          width={400}
          height={192}
          format="webp"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
        <span class="badge badge-primary absolute top-2 right-2 gap-1">
          <span aria-hidden="true">{cat.icon}</span> {cat.label}
        </span>
      </figure>
    )}
    <div class="card-body p-4">
      {formattedDate && (
        <time datetime={pubDate} class="text-xs text-base-content/70">{formattedDate}</time>
      )}
      {series && seriesOrder && seriesTotal && (
        <span class="text-xs text-primary/80 font-medium">
          Part {seriesOrder} of {seriesTotal}
          <span aria-hidden="true"> &middot; </span>
          <span class="text-base-content/70 font-normal">{series}</span>
        </span>
      )}
      <h2 class="card-title text-lg">
        {title}
        {badge && <span class="badge badge-secondary badge-sm">{badge}</span>}
      </h2>
      <p class="text-sm text-base-content/70 line-clamp-2">{desc}</p>
      {tags.length > 0 && (
        <div class="card-actions mt-2">
          {tags.map((tag: string) => (
            <span class="badge badge-outline badge-sm">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
