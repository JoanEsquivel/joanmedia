---
import { Image } from "astro:assets";

interface Props {
  title: string;
  img?: string;
  desc: string;
  url: string;
  badge?: string;
  tags?: string[];
  pubDate?: string;
}

const { title, img, desc, url, badge, tags = [], pubDate } = Astro.props;

const month = pubDate ? new Date(pubDate).toISOString().slice(0, 7) : "";
const formattedDate = pubDate
  ? new Date(pubDate).toLocaleDateString("en-US", {
      month: "long",
      day: "2-digit",
      year: "numeric",
    })
  : "";
---

<article
  class="blog-card card bg-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group overflow-hidden"
  data-title={title?.toLowerCase()}
  data-description={desc?.toLowerCase()}
  data-tags={tags.join(",").toLowerCase()}
  data-month={month}
  data-date={pubDate}
>
  <a href={url} class="block focus-visible:outline-offset-4">
    {img && (
      <figure class="h-48 overflow-hidden">
        <Image
          src={img}
          alt=""
          loading="lazy"
          decoding="async"
          width={400}
          height={192}
          format="webp"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </figure>
    )}
    <div class="card-body p-4">
      {formattedDate && (
        <time datetime={pubDate} class="text-xs text-base-content/70">{formattedDate}</time>
      )}
      <h2 class="card-title text-lg">
        {title}
        {badge && <span class="badge badge-secondary badge-sm">{badge}</span>}
      </h2>
      <p class="text-sm text-base-content/70 line-clamp-2">{desc}</p>
      {tags.length > 0 && (
        <div class="card-actions mt-2">
          {tags.map((tag: string) => (
            <span class="badge badge-outline badge-sm">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
