---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AIBlogCard from "../../components/AIBlogCard.astro";
import AIBlogFilterBar from "../../components/AIBlogFilterBar.astro";
import { getCollection } from "astro:content";
import createSlug from "../../lib/createSlug";
import type { GetStaticPathsOptions } from "astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("ai-blog");
  posts.sort((a, b) => {
    const dateDiff = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
    if (dateDiff !== 0) return dateDiff;
    if (a.data.series && b.data.series && a.data.series === b.data.series) {
      return (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0);
    }
    return 0;
  });
  return paginate(posts, { pageSize: 999 });
}

const { page } = Astro.props;
const posts = page.data;

const allTags = [...new Set(posts.map((post: any) => post.data.tags || []).flat())] as string[];
const allMonths = [...new Set(
  posts.map((post: any) => {
    const d = new Date(post.data.pubDate);
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  })
)].sort((a, b) => b.localeCompare(a));

// Build series metadata
const seriesCounts = new Map<string, number>();
for (const post of posts) {
  if (post.data.series) {
    seriesCounts.set(post.data.series, (seriesCounts.get(post.data.series) || 0) + 1);
  }
}
const allSeries = [...seriesCounts.keys()].sort();
---

<BaseLayout title="AI Blog" activeItemID="ai-blog">
  <div class="mb-8">
    <h1 class="text-4xl font-bold tracking-tight">AI Blog</h1>
    <p class="text-base-content/70 mt-2">AI-generated research on QA, development, cloud, and more.</p>
  </div>

  <AIBlogFilterBar allTags={allTags} allMonths={allMonths} allSeries={allSeries} />

  {posts.length === 0 ? (
    <div class="bg-base-200 border-l-4 border-secondary w-full p-4">
      <p class="font-bold">Sorry!</p>
      <p>There are no AI blog posts to show at the moment. Check back later!</p>
    </div>
  ) : (
    <div id="ai-blog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post: any) => (
        <AIBlogCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/ai-blog/" + createSlug(post.data.title, post.slug)}
          badge={post.data.badge}
          tags={post.data.tags}
          pubDate={post.data.pubDate.toISOString()}
          category={post.data.category}
          series={post.data.series}
          seriesOrder={post.data.seriesOrder}
          seriesTotal={post.data.series ? seriesCounts.get(post.data.series) : undefined}
        />
      ))}
    </div>
  )}

  <!-- Pagination below the grid -->
  <nav id="ai-blog-pagination" class="flex items-center justify-center gap-2 mt-10 mb-8" aria-label="AI Blog pagination"></nav>
</BaseLayout>
